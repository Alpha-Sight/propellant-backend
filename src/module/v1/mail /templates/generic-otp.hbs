<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
</head>
<body style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; margin: 0; padding: 0; background-color: #f5f5f5; color: #333333;">
    <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
            <td style="padding: 30px 0;">
                <table align="center" role="presentation" width="600" border="0" cellspacing="0" cellpadding="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #0056b3; padding: 20px 30px; text-align: center;">
                            <h1 style="color: white; margin: 0; font-size: 24px;">Propellant HR</h1>
                        </td>
                    </tr>
                    <!-- Body -->
                    <tr>
                        <td style="padding: 30px;">
                            <h2 style="margin-top: 0; color: #333333;">Verification Code</h2>
                            <p>Hello,</p>
                            <p>{{message}}</p>
                            
                            <div style="background-color: #f5f7fa; border-left: 4px solid #0056b3; padding: 15px; margin: 20px 0; text-align: center;">
                                <span style="font-size: 28px; font-weight: bold; letter-spacing: 4px; color: #0056b3;">{{code}}</span>
                            </div>
                            
                            <p>This code will expire in {{expirationTime}} minutes.</p>
                            <p>If you didn't request this code, please ignore this email or contact our support team.</p>
                            
                            <p>Best regards,<br>Propellant HR Team</p>
                        </td>
                    </tr>
                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #f5f7fa; padding: 20px 30px; text-align: center; font-size: 12px; color: #666;">
                            <p style="margin: 0 0 10px 0;">© 2023 Propellant HR. All rights reserved.</p>
                            <p style="margin: 0 0 10px 0;">
                                <a href="https://propellanthr.com" style="color: #0056b3; text-decoration: none;">propellanthr.com</a>
                            </p>
                            <p style="margin: 0;">
                                If you would like to unsubscribe from these emails, 
                                <a href="mailto:unsubscribe@propellanthr.com?subject=Unsubscribe" style="color: #0056b3; text-decoration: underline;">click here</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
